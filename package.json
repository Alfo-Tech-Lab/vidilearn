{
  "name": "vidilearn",
  "version": "2.0.2",
  "description": "AI-native universal knowledge ingestion and semantic retrieval engine with hybrid BM25+vector search, MCP server integration, and offline embeddings",
  "type": "module",
  "bin": {
    "vidilearn": "./bin/vidilearn.js"
  },
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bin/vidilearn.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "audit": "node bin/vidilearn.js audit",
    "doctor": "node bin/vidilearn.js doctor"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "youtube",
    "transcript",
    "rag",
    "retrieval",
    "vector-search",
    "bm25",
    "hybrid-search",
    "embeddings",
    "mcp",
    "semantic-search",
    "ai",
    "knowledge-base",
    "offline",
    "local-llm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alfo-Tech-Lab/vidilearn.git"
  },
  "homepage": "https://github.com/Alfo-Tech-Lab/vidilearn#readme",
  "bugs": {
    "url": "https://github.com/Alfo-Tech-Lab/vidilearn/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@huggingface/transformers": "^3.1.2",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "js-yaml": "^5.2.0",
    "jsdom": "^23.0.0",
    "mammoth": "^1.12.0",
    "node-cache": "^5.1.2",
    "ora": "^7.0.1",
    "pdf-parse": "^2.4.5",
    "rss-parser": "^3.13.0",
    "sqlite-vec": "^0.1.9",
    "turndown": "^7.1.2",
    "youtube-transcript": "^1.0.6",
    "yt-dlp-exec": "^1.0.2"
  },
  "optionalDependencies": {
    "playwright": "^1.40.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
